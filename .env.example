# ============================================
# TCM EClinic - 环境配置模板
# ============================================
# 复制此文件为 .env 并根据环境调整参数
#   cp .env.example .env
#
# .env 已被 .gitignore 忽略，不会提交到仓库

# ---- 数据库类型 ----
# postgres = PostgreSQL（生产环境，需先启动 PG 服务）
# sqlite   = SQLite（开发/演示，零外部依赖）
DB_TYPE=postgres

# ---- PostgreSQL 连接 ----
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tcm_eclinic_db
PG_USER=postgres
PG_PASSWORD=

# ---- 应用信息 ----
APP_NAME=中医 EClinic
APP_VERSION=2.0.0-postgres-ready
APP_AUTHOR=李玉贤工作室

# ---- 日志 ----
LOG_LEVEL=INFO
