# ------------------------------------------------------
# TCM_eclinic 专用 .gitignore
# Python + PyQt + 打包工具 + 数据排除
# ------------------------------------------------------

# ======================
# 1) Python 编译垃圾
# ======================
__pycache__/
*.py[cod]
*$py.class

# ======================
# 2) 虚拟环境
# ======================
venv/
.venv/
env/
ENV/

# ======================
# 3) 构建/发布相关（PyInstaller、cx_Freeze等）
# ======================
build/
dist/
*.spec             # PyInstaller
*.manifest
*.egg-info/
*.egg

# Nuitka
__nuitka_build__/ 
.nuitka/

# ======================
# 4) 日志与缓存
# ======================
*.log
*.tmp
*.bak
*.swp

# pytest
.cache/
.pytest_cache/

# notebook checkpoints
.ipynb_checkpoints/

# ======================
# 5) 本地配置文件（IDE）
# ======================

# VSCode
.vscode/
# JetBrains / PyCharm
.idea/
*.iml

# ======================
# 6) 系统垃圾文件
# ======================
Thumbs.db
Desktop.ini
.DS_Store
*$~

# ======================
# 7) Qt / PyQt 相关
# ======================
# 编译后的 qt ui/python 文件（如自动生成）
ui_*.py
*_rc.py

# ======================
# 8) 数据（你要求忽略 samples ）
# ======================
# 忽略所有样本原始数据
data/samples/

# 如果 data/ 里有模型、密钥等，可继续加:
# data/models/
# data/private_keys/

# ======================
# 9) 临时脚本文件
# ======================
*.old
*.orig
*.rej

# ======================
# 10) 本地运行凭证（如有）
# ======================
*.token
*.key
*.pem

# ======================
# 11) Windows Python Launcher 输出
# ======================
pip-selfcheck.json

# ======================
# 12) 你项目特定忽略（建议可继续补充）
# ======================
# 例如 docx 临时分析输出等
# data/tmp/
